# Supabase (obrigatório)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-publica

# Google Calendar — OAuth no frontend (cliente + barbeiro conectam agenda)
VITE_GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# NÃO coloque GOOGLE_CLIENT_SECRET no .env local — use secrets das Edge Functions no Supabase:
# GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, WHATSAPP_ACCESS_TOKEN, WHATSAPP_PHONE_ID
