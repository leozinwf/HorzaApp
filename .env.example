# Supabase (obrigatório)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-publica

# Google Calendar — OAuth no frontend (cliente + barbeiro conectam agenda)
VITE_GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# Stripe Connect — OAuth para barbearia receber pagamentos de clientes
VITE_STRIPE_CLIENT_ID=ca_xxx

# Secrets das Edge Functions (Supabase Dashboard → Edge Functions → Secrets):
# STRIPE_SECRET_KEY=sk_test_xxx          — mesma conta Stripe da plataforma Horza
# STRIPE_BILLING_WEBHOOK_SECRET=whsec_xxx — webhook endpoint: stripe-billing-webhook
# SITE_URL=http://localhost:5174         — origem permitida nos redirects de checkout/portal
# BILLING_ALLOWED_ORIGINS=https://app.horza.com.br,http://localhost:5174  — opcional, múltiplas origens

# Após criar Products/Prices no Stripe Dashboard, atualize no Supabase:
# UPDATE plans SET stripe_price_id = 'price_xxx', stripe_product_id = 'prod_xxx' WHERE slug = 'pro';
# UPDATE plans SET stripe_price_id = 'price_yyy', stripe_product_id = 'prod_yyy' WHERE slug = 'plus';

# Deploy das functions de billing:
# supabase functions deploy create-billing-checkout create-billing-portal stripe-billing-webhook

# NÃO coloque GOOGLE_CLIENT_SECRET no .env local — use secrets das Edge Functions no Supabase:
# GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, WHATSAPP_ACCESS_TOKEN, WHATSAPP_PHONE_ID
